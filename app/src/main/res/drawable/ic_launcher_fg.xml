<?xml version="1.0" encoding="utf-8"?>
<!--
  Capa frontal del ícono adaptativo: el logo real de Toppis, con inset para que
  quede dentro de la zona segura (66dp de 108dp) y no lo recorte la máscara del
  launcher (círculo, squircle, etc.).
-->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/toppis_logo"
    android:insetLeft="18%"
    android:insetTop="18%"
    android:insetRight="18%"
    android:insetBottom="18%" />
